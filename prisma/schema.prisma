generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  connectionLimit = 5
}
model Company {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  normalizedName String   @unique
  industry       String?
  headquarters   String?
  foundedYear    Int?
  headcountRange String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salaries Salary[]

  @@index([normalizedName])
  @@index([slug])
}

model Salary {
  id                String   @id @default(cuid())
  companyId         String
  role              String
  level             String
  location          String
  currency          String
  experienceYears   Int
  baseSalary        Int
  bonus             Int      @default(0)
  stock             Int      @default(0)
  totalCompensation Int
  source            String
  confidenceScore   Float
  isVerified        Boolean  @default(false)
  submittedAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, level, location])
  @@index([totalCompensation])
  @@index([submittedAt])
  @@index([location, level])
}